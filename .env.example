# MDMesh deployment config. Copy to .env (or let ./setup.sh generate it) and fill in.
# .env is gitignored — it holds secrets. Generated secrets should be alphanumeric.

# --- Database (not published to the host) ---
DB_NAME=hmdm
DB_USER=hmdm
# REQUIRED. Generate, e.g.: openssl rand -hex 24
DB_PASSWORD=

# --- Server ---
# REQUIRED. Public base URL devices + the console use (no trailing slash). This is also embedded in
# the enrollment QR so agents know where to reach. e.g. https://mdm.example.com  or  https://mdm.acme.dev
BASE_URL=
# REQUIRED. Shared signing secret. Generate, e.g.: openssl rand -hex 24
HASH_SECRET=
# 1 = require signed enrollment (more secure; needs the secret on the agent too). 0 = off.
SECURE_ENROLLMENT=0

# --- Edge (Caddy) ---
# own-domain  → SITE_ADDRESS=mdm.example.com  (Caddy gets a Let's Encrypt cert; set ACME_EMAIL)
# cloudflare  → SITE_ADDRESS=:80              (Cloudflare terminates TLS)
SITE_ADDRESS=:80
ACME_EMAIL=

# --- Cloudflare Tunnel (only the cloudflare profile) ---
# Create a tunnel in Cloudflare Zero Trust, route its public hostname to http://caddy:80, and paste
# the tunnel token here. Then: docker compose --profile cloudflare up -d
TUNNEL_TOKEN=

# --- Auto-update (updater/recovery supervisor) ---
# The GitHub repo to poll for releases (owner/name), the channel, and this deployment's current
# version (set to the deployed release tag; 0.0.0 means "any release shows as available").
GITHUB_REPO=
UPDATE_CHANNEL=stable
POLL_INTERVAL_HOURS=6
CURRENT_VERSION=0.0.0
# Optional GitHub token to raise the API rate limit / read a private repo.
GITHUB_TOKEN=

# --- SMTP (optional; password-recovery emails) ---
SMTP_HOST=
SMTP_PORT=25
SMTP_FROM=mdm@localhost
SMTP_USERNAME=
SMTP_PASSWORD=
