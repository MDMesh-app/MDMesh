<?xml version="1.0" encoding="utf-8"?>
<!--
    Pre-API-26 launcher fallback (no adaptive-icon support). A plain layer-list
    over the brand background with the shield foreground. Real density-specific PNGs
    can replace this later; vector layers keep the scaffold asset-free.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/ic_launcher_background" />
    <item android:drawable="@drawable/ic_launcher_foreground" />
</layer-list>
