<?xml version="1.0" encoding="UTF-8"?>
<!-- Dev context.xml for the control plane, filled from install/context_template.xml.
     Values target the docker-compose.dev.yml network (db host = "postgres"). -->
<Context>
    <Parameter name="JDBC.driver"   value="org.postgresql.Driver"/>
    <Parameter name="JDBC.url"      value="jdbc:postgresql://postgres:5432/hmdm"/>
    <Parameter name="JDBC.username" value="hmdm"/>
    <Parameter name="JDBC.password" value="hmdm"/>

    <Parameter name="base.directory"  value="/opt/hmdm"/>
    <Parameter name="files.directory" value="/opt/hmdm/files"/>
    <Parameter name="base.url"        value="http://localhost:8080"/>

    <Parameter name="usage.scenario"   value="private"/>
    <Parameter name="secure.enrollment" value="0"/>
    <Parameter name="hash.secret"      value="dev-only-change-me"/>

    <Parameter name="plugins.files.directory" value="/opt/hmdm/plugins"/>
    <Parameter name="plugin.devicelog.persistence.config.class"
               value="com.hmdm.plugins.devicelog.persistence.postgres.DeviceLogPostgresPersistenceConfiguration"/>
    <Parameter name="role.orgadmin.id" value="2"/>

    <Parameter name="swagger.host"      value="localhost:8080"/>
    <Parameter name="swagger.base.path" value="/rest"/>

    <Parameter name="initialization.completion.signal.file" value="/opt/hmdm/initialized.txt"/>
    <Parameter name="log4j.config" value="file:///opt/hmdm/log4j-hmdm.xml"/>
    <Parameter name="aapt.command" value="aapt"/>

    <!-- Embedded MQTT broker (notification module) listens on 31000 inside the container. -->
    <Parameter name="mqtt.server.uri" value="localhost:31000"/>
    <Parameter name="mqtt.auth" value="1"/>

    <Parameter name="device.fast.search.chars" value="5"/>

    <!-- SMTP not configured in dev; password recovery email will no-op. -->
    <Parameter name="smtp.host" value=""/>
    <Parameter name="smtp.port" value="25"/>
    <Parameter name="smtp.ssl" value="false"/>
    <Parameter name="smtp.starttls" value="false"/>
    <Parameter name="smtp.username" value=""/>
    <Parameter name="smtp.password" value=""/>
    <Parameter name="smtp.from" value="dev@localhost"/>

    <Parameter name="email.recovery.subj" value="/opt/hmdm/emails/_LANGUAGE_/recovery_subj.txt"/>
    <Parameter name="email.recovery.body" value="/opt/hmdm/emails/_LANGUAGE_/recovery_body.txt"/>
</Context>
