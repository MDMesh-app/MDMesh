# Base URL prefix for the Headwind REST API.
# Leave as "/rest" to use the Vite dev proxy (see vite.config.ts) or to be
# served from the same origin as the server in production.
# Set to an absolute URL (e.g. https://mdm.example.com/rest) to target a
# remote server directly. Note: cross-origin requests require the server to
# send CORS + credentialed-cookie headers, since auth is session based.
VITE_API_BASE=/rest

# Dev-only: where the Vite proxy forwards /rest requests.
# Consumed by vite.config.ts, not by the app at runtime.
VITE_DEV_PROXY_TARGET=http://localhost:8080
